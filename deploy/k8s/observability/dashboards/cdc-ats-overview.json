{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["cdc-ats", "ats", "overview"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "CDC ATS - Overview",
  "uid": "cdc-ats-overview",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "app",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(http_requests_total, app)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "label": "Service",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Request throughput & errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Throughput - requests/sec by service",
      "description": "Real metric: http_requests_total (packages/common/src/lib/metrics.ts). Per-service RPS.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_requests_total{app=~\"$app\"}[1m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate - % 5xx by service",
      "description": "5xx / total, per service. Alert HighErrorRate fires at >5% (30-alert-rules.yaml).",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] }
        }
      },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_requests_total{app=~\"$app\", status=~\"5..\"}[5m])) / clamp_min(sum by (app) (rate(http_requests_total{app=~\"$app\"}[5m])), 1e-9)",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by service",
      "description": "histogram_quantile over http_request_duration_seconds_bucket. SLO p95<1.5s (load-tests/stress-10k.js).",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1.5 } ] }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (app, le) (rate(http_request_duration_seconds_bucket{app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all selected services)",
      "description": "Aggregate quantiles across the selected services.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{app=~\"$app\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=~\"$app\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{app=~\"$app\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "row",
      "title": "Scaling & capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "Replica count - HPA current replicas",
      "description": "kube-state-metrics: kube_horizontalpodautoscaler_status_current_replicas (deploy/k8s/55-autoscalers.yaml). Requires kube-state-metrics.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"cdc-ats\"}",
          "legendFormat": "{{horizontalpodautoscaler}}",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"cdc-ats\"}",
          "legendFormat": "{{horizontalpodautoscaler}} (max)",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth (BullMQ) - NEEDS EXPORTER",
      "description": "PLACEHOLDER. bullmq_queue_waiting is NOT exported yet (see 30-alert-rules.yaml queue-backlog group). This panel stays empty until a queue-depth exporter / KEDA Redis scaler is wired. Kept so the wiring target is visible.",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "sum by (queue) (bullmq_queue_waiting)",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Process resources (prom-client defaults)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "type": "timeseries",
      "title": "CPU seconds/sec by service",
      "description": "process_cpu_seconds_total (prom-client collectDefaultMetrics).",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (app) (rate(process_cpu_seconds_total{app=~\"$app\"}[1m]))", "legendFormat": "{{app}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Resident memory by service",
      "description": "process_resident_memory_bytes (prom-client collectDefaultMetrics).",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (app) (process_resident_memory_bytes{app=~\"$app\"})", "legendFormat": "{{app}}", "refId": "A" }
      ]
    }
  ]
}
