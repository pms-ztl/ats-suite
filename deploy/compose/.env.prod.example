# ═══════════════════════════════════════════════════════════════════════════════
#  CDC ATS - scaled single-host prod compose env TEMPLATE.
#  Copy to `.env` in this directory and fill in REAL values. NEVER commit `.env`.
#    cp .env.prod.example .env
#
#  Secrets marked REQUIRED must be set or compose refuses to start (the `:?` guard
#  in docker-compose.prod.yml). Generate strong random values:
#    openssl rand -base64 48
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED secrets ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-use-openssl-rand
INTERNAL_SERVICE_TOKEN=change-me-random-32-chars
EMBED_SECRET=change-me-random-32-chars
# AES-256-GCM key for encrypting TenantIntegration / OA provider secrets at rest.
# MUST be a 32-byte key (openssl rand -hex 32 gives 64 hex chars = 32 bytes).
ATS_CONFIG_ENC_KEY=change-me-64-hex-chars-32-bytes

POSTGRES_PASSWORD=change-me-strong-db-password
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-strong-minio-password

# ── LLM provider (optional - AI features degrade gracefully if unset) ─────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_OVERRIDE=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AGENT_MAX_OUTPUT_TOKENS=8000
# Agentic knobs (see docker-compose.demo.yml comments). Leave blank/0 for a
# cost-capped pilot; turn on for richer signal at higher token cost.
AGENTIC_COPILOT=
AGENTIC_RESUME_VERIFY=0
RESUME_GITHUB_CORROBORATE=0

# CORS origin for the browser (set to your public URL, e.g. https://ats.example.com).
CORS_ORIGIN=

# ── Edge ─────────────────────────────────────────────────────────────────────
HTTP_PORT=80
# HTTPS_PORT=443   # enable after mounting certs into ./nginx/certs

# ── Replica counts for the hot-path services ─────────────────────────────────
# Size these to the host: total service processes ≈ sum of replicas. On an 8-core
# box, GATEWAY=3 / JOB=3 / RESUME=2 / SCREENING=2 / FRONTEND=2 is a sane start.
GATEWAY_REPLICAS=3
JOB_REPLICAS=3
RESUME_REPLICAS=2
SCREENING_REPLICAS=2
FRONTEND_REPLICAS=2

# ── Postgres tuning (size to the host; PgBouncer keeps backend conns bounded) ─
PG_MAX_CONNECTIONS=400
PG_SHARED_BUFFERS=1GB
PG_WORK_MEM=8MB
PG_EFFECTIVE_CACHE=4GB

# ── PgBouncer ────────────────────────────────────────────────────────────────
# SESSION is the SAFE default for RLS (per-request SET app.current_tenant_id).
# Switch to `transaction` ONLY after the SET-LOCAL audit (see the pgbouncer block
# in docker-compose.prod.yml). Sizing: MAX_CLIENT_CONN must exceed
# Σ(service replicas × connection_limit); DEFAULT_POOL_SIZE is backend conns/db.
PGBOUNCER_POOL_MODE=session
PGBOUNCER_MAX_CLIENT_CONN=2000
PGBOUNCER_DEFAULT_POOL_SIZE=25

# Per-service Prisma pool size (the ?connection_limit= in each *_DATABASE_URL).
# Keep small; the pooler is the real multiplexer. job-service gets its own.
DB_CONN_LIMIT=5
JOB_DB_CONN_LIMIT=8

# ── Redis ────────────────────────────────────────────────────────────────────
# noeviction is set in compose so BullMQ jobs are never dropped under memory
# pressure (they error instead, which is the safe failure). Size to the host.
REDIS_MAXMEMORY=1gb

# ── Async pipeline throughput ────────────────────────────────────────────────
RESUME_PARSE_CONCURRENCY=8
RESUME_PARSE_RATE_MAX=60
SCREENING_CONCURRENCY=6
SCREENING_RATE_MAX=30
