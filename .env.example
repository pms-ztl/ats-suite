# ── Common (every service reads these) ────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
SERVICE_VERSION=0.0.1
JAEGER_ENDPOINT=http://localhost:14268/api/traces
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6381

# ── api-gateway only ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars-please
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d
JWT_ISSUER=cdc-ats
JWT_AUDIENCE=cdc-ats-api
CORS_ORIGIN=http://localhost:3000
SUPER_ADMIN_SECRET=optional-static-key-for-cli-tooling

# Service routing table (gateway → backend services)
IDENTITY_SERVICE_URL=http://localhost:4001
TENANT_SERVICE_URL=http://localhost:4002
BILLING_SERVICE_URL=http://localhost:4003
JOB_SERVICE_URL=http://localhost:4004
CANDIDATE_SERVICE_URL=http://localhost:4005
INTERVIEW_SERVICE_URL=http://localhost:4006
RESUME_SERVICE_URL=http://localhost:4007
SCREENING_SERVICE_URL=http://localhost:4008
NOTIFICATION_SERVICE_URL=http://localhost:4009
# assessment-service (online assessments / OA), port 4014. WF7 wires the gateway
# proxy: /api/assessments (module-gated authoring), /api/public/assessment (public
# take), and /api/internal/judge0/callback (external Judge0 verdict callback).
ASSESSMENT_SERVICE_URL=http://localhost:4014

# Internal service-to-service shared secret (defense in depth)
INTERNAL_SERVICE_TOKEN=change-me-internal-shared-secret

# ── WF2 — embeddable surfaces security groundwork ─────────────────────
# EMBED_SECRET (api-gateway): signing secret for minting/verifying embed tokens
# used by the future /embed/* + /api/embed/* surfaces. Generate a strong value,
# >=32 random bytes as hex:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
EMBED_SECRET=change-me-embed-signing-secret-min-32-bytes-hex
# ATS_CONFIG_ENC_KEY (notification-service + assessment-service): AES-256-GCM key
# for @cdc-ats/common encryptConfig/decryptConfig. MUST decode to EXACTLY 32 bytes;
# supply as 64 hex chars:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ATS_CONFIG_ENC_KEY=change-me-32-byte-aes-256-key-as-64-hex-chars

# ── Per-service database URLs (each service has its own DB) ───────────
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/identity_db
TENANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tenant_db
BILLING_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/billing_db
JOB_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/job_db
CANDIDATE_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/candidate_db
INTERVIEW_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/interview_db
RESUME_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/resume_db
SCREENING_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/screening_db
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/notification_db
# WF3 — assessment-service (online assessments). Two URLs: the admin (superuser)
# URL is used by migrations + prisma/apply-rls.ts; the APP URL points at the
# non-superuser ats_app role so RLS policies apply on request paths.
ASSESSMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/assessment_db
ASSESSMENT_APP_DATABASE_URL=postgresql://ats_app:ats_app_dev_pw@localhost:5434/assessment_db

# WF7/G7 — isolated Judge0 sidecar that runs candidate CODING submissions. The
# grading worker POSTs /submissions/batch here; Judge0 delivers async verdicts to
# JUDGE0_CALLBACK_BASE_URL + /api/internal/judge0/callback (the PUBLIC gateway
# proxy). Keep Judge0 on its own network — never expose it publicly.
JUDGE0_URL=http://judge0:2358
JUDGE0_CALLBACK_BASE_URL=http://api-gateway:4000
# Optional hosted-Judge0 auth (self-host X-Auth-Token, or RapidAPI key/host).
# JUDGE0_AUTH_TOKEN=
# JUDGE0_RAPIDAPI_KEY=
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# ── AI / agent keys (services that run agents) ────────────────────────
# OPENROUTER_API_KEY is the primary LLM provider used by the demo. This is the
# one key you must set for the Docker demo (resume screening, JD author, etc.).
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── notification-service only ─────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@cdc-ats.local
SLACK_BOT_TOKEN=

# ── Frontend app URL (used by Stripe success/cancel redirects) ────────
APP_URL=http://localhost:3000

# ── Phase 34c — Inbound email (notification-service) ──────────────────
# Wire one of these in your SMTP provider's "Inbound Parse" dashboard:
#   SendGrid:  POST https://<your-host>/api/inbound-email/sendgrid
#   Mailgun:   POST https://<your-host>/api/inbound-email/mailgun
#   Postmark:  POST https://<your-host>/api/inbound-email/postmark
# Address scheme: jobs+<tenant-slug>@your-domain.com
MAILGUN_WEBHOOK_SIGNING_KEY=
POSTMARK_WEBHOOK_TOKEN=

# ── Phase 34d — Cloud sync OAuth (notification-service) ───────────────
# Google Drive: https://console.cloud.google.com → OAuth client (Web app)
#   Redirect URI: https://<your-api-host>/api/cloud-sync/google-drive/callback
# Dropbox: https://www.dropbox.com/developers/apps → Scoped app
#   Redirect URI: https://<your-api-host>/api/cloud-sync/dropbox/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
# Optional: disable the poll worker in test/CI runs
# DISABLE_CLOUD_SYNC_WORKER=true

# ── Phase 34e — SMS/WhatsApp apply via Twilio (notification-service) ──
# Per-tenant numbers live in TenantIntegration; this is the global auth.
# Webhook config in Twilio Console:
#   Voice & Messaging → Phone Number → Messaging "WHEN A MESSAGE COMES IN"
#   POST https://<your-api-host>/api/twilio/sms
# WhatsApp: same endpoint at /api/twilio/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Phase 35b — Resume binary storage (resume-service) ────────────────
# S3-compatible. AWS S3 in prod; MinIO in local docker-compose dev.
# When unset, resume-service falls back to text-only mode (binary not
# persisted; extracted text still parsed and saved to DB).
#   Dev (MinIO):  endpoint=http://localhost:9000, forcePathStyle=true
#   Prod (AWS):   endpoint unset, forcePathStyle unset
S3_BUCKET=cdc-ats-resumes
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=http://localhost:9000      # uncomment for MinIO
# S3_FORCE_PATH_STYLE=true               # uncomment for MinIO

# ── Phase 36a — OCR for scanned-image PDFs (resume-service) ────────────
# On by default now (bulk-archive ingest OCRs image entries). Adds ~12 MB
# WASM model + ~1-3s/page CPU cost. Set to "false" to disable OCR entirely.
# ENABLE_OCR=true

# ── Bulk-archive ingest throughput (resume-service) ───────────────────
# Parse-worker BullMQ concurrency + per-minute rate limiter. Raised from the
# safe single-upload defaults (3 / 10-per-min) so a 1k-10k file ZIP drains
# quickly. Tune down if the LLM/extract pipeline saturates CPU or hits caps.
# RESUME_PARSE_CONCURRENCY=8
# RESUME_PARSE_RATE_MAX=60

# ── Bulk-screening throughput (screening-service) ─────────────────────
# Screening-worker BullMQ concurrency + per-minute rate limiter. Plan-gating
# and cost-cap logic are unaffected; this only controls parallelism/pacing.
# SCREENING_CONCURRENCY=6
# SCREENING_RATE_MAX=30

# ── Phase 37h — GitHub corroboration (ai-engine) ──────────────────────
# Optional. Unauthenticated GitHub API: 60 req/hour per IP. With token: 5000/hour.
# Recommended in prod so a busy tenant doesn't get rate-limited mid-day.
# GITHUB_TOKEN=ghp_...

# ── Phase 30 — Stripe self-serve plan purchases (billing-service) ─────
# Get keys from https://dashboard.stripe.com/test/apikeys
# Get the webhook secret from `stripe listen --forward-to localhost:4000/api/stripe/webhook`
# (development) or from the Stripe dashboard's webhook endpoint (production).
# Create the prices in Stripe with `mode=subscription, interval=month` and
# paste the price_xxx ids below.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
# Optional — defaults to {APP_URL}/billing?stripe=success|cancel
# STRIPE_SUCCESS_URL=
# STRIPE_CANCEL_URL=
