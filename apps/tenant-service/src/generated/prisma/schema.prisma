generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

enum TenantPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PlanChangeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Tenant {
  id              String       @id @default(uuid())
  name            String
  slug            String       @unique
  plan            TenantPlan   @default(FREE)
  status          TenantStatus @default(TRIAL)
  trialEndsAt     DateTime?
  logoUrl         String?
  website         String?
  industry        String?
  companySize     String?
  dataRegion      String       @default("us-east-1")
  isolationConfig Json         @default("{}")
  settings        Json         @default("{}")

  // Phase 20 — tenant self-service branding.
  // Colors stored as hex strings (e.g. "#1A8FFF"); validated at write time.
  // Career portal copy is plain text / sanitized HTML so a tenant can put
  // their own welcome message + "About us" on the public jobs board.
  brandPrimaryColor          String?
  brandSecondaryColor        String?
  brandAccentColor           String?
  brandTagline               String? @db.VarChar(160)
  careerPortalWelcomeMessage String? @db.Text
  careerPortalAboutHtml      String? @db.Text
  careerPortalHeroImageUrl   String?

  // Phase 20 — data retention. dataRetentionDays = how long candidate data
  // sits after their last activity before the nightly purge worker invokes
  // GDPR-delete. Floor enforced at write time via PLAN_LIMITS to keep
  // tenants from setting < legal minimum.
  dataRetentionDays Int @default(730)

  // Phase 30 — Stripe self-serve. stripeCustomerId is created on first
  // checkout (or surfaced after the first paid plan starts via webhook).
  // Stored on Tenant so we can re-use the same customer across plan changes
  // and across the Customer Portal session for managing payment methods,
  // invoices, and cancellation. Source of truth for subscription state still
  // lives in billing-service's StripeSubscription model.
  stripeCustomerId String?

  // Phase 29 — first-run onboarding wizard state.
  //   onboardingSteps     { branding: ISO, team: ISO, requisition: ISO,
  //                         rounds: ISO, share: ISO } — completion timestamps
  //   onboardingDismissedAt set when user clicks "skip / maybe later"
  //   onboardingCompletedAt set when all 5 steps done
  // Wizard shows on dashboard load when both …DismissedAt and …CompletedAt
  // are null. Each step writes its own timestamp so we can resume partial
  // progress if a user closes the browser mid-wizard.
  onboardingSteps       Json      @default("{}")
  onboardingDismissedAt DateTime?
  onboardingCompletedAt DateTime?

  // WF2 — embeddable widget groundwork. The exact set of external origins this
  // tenant has explicitly authorized to frame /embed/* + call /api/embed/*.
  // Each entry is a normalized https origin ("https://host[:port]", no path).
  // Defaulted empty => additive, no backfill needed; the actual db-push lands
  // in WF3, the /embed routes + SDK in WF9. Fail-CLOSED security model: an empty
  // array means NO external site may frame this tenant, so framing stays denied
  // until an admin opts a specific origin in. Validated at write time in
  // branding.ts (URL-parsed, https-only, origin-only — no paths/wildcards).
  embedAllowedOrigins String[] @default([])

  // WF3 — dashboard/theme defaults groundwork (additive, defaulted so the frozen
  // v1 demo cannot regress; the actual db-push lands in the migrator-rebuild
  // recipe, the dashboard renderer + theming layer arrive in later WFs).
  //   dashboardThemeTokens   the tenant-wide design-token overrides (CSS custom
  //                          properties / palette) applied to every dashboard for
  //                          this tenant. Shape: a flat map of token name -> value;
  //                          {} means "use the platform defaults" (no override).
  //   defaultColorMode       the tenant's default color scheme for new users who
  //                          have not set a per-user preference. One of
  //                          "system" | "light" | "dark"; "system" follows the OS.
  //   defaultDashboardByRole maps a role key (ADMIN/RECRUITER/HIRING_MANAGER/...)
  //                          to the dashboardKey that role lands on by default.
  //                          {} means "use the platform default home for every
  //                          role"; entries are additive overrides per role.
  dashboardThemeTokens   Json   @default("{}")
  defaultColorMode       String @default("system")
  defaultDashboardByRole Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planChangeRequests PlanChangeRequest[]

  @@index([status])
  @@index([plan])
}

model PlanChangeRequest {
  id                String           @id @default(uuid())
  tenantId          String
  fromPlan          TenantPlan
  toPlan            TenantPlan
  status            PlanChangeStatus @default(PENDING)
  reason            String?
  requestedByUserId String
  requestedAt       DateTime         @default(now())
  reviewedByUserId  String?
  reviewedAt        DateTime?
  decisionNote      String?

  // Phase 33a — super-admin approval gate for paid plans.
  //
  // Before 33a: APPROVE immediately flipped Tenant.plan (Phase 22).
  // After  33a: APPROVE for STARTER/PROFESSIONAL only GRANTS approval —
  // the tenant must then pay via Stripe Checkout before Tenant.plan flips.
  // ENTERPRISE keeps the old behaviour (custom contract, no Stripe).
  //
  //   paymentMethod    "STRIPE"  → requires Checkout completion to activate
  //                    "ENTERPRISE_CONTRACT" → flips on approval
  //                    "FREE"   → downgrade to free; flips on approval
  //   activatedAt      null until Tenant.plan actually changes. Set by:
  //                    - tenant-service on approval for ENTERPRISE/FREE
  //                    - Stripe webhook syncSubscription() for STARTER/PROFESSIONAL
  paymentMethod String?
  activatedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([requestedAt])
}
