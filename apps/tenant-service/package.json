{
  "name": "@cdc-ats/tenant-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@cdc-ats/common": "*",
    "@cdc-ats/contracts": "*",
    "@cdc-ats/nats-client": "*",
    "@prisma/client": "^6.0.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.5",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "rimraf": "^6.0.1"
  }
}
