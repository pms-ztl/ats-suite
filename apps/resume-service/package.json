    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "pino": "^9.5.0",
