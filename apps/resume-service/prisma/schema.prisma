generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("RESUME_DATABASE_URL")
}

enum BulkUploadStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

model Resume {
  id               String   @id @default(cuid())
  tenantId         String
  candidateId      String   @unique  // FK to candidate-service (no Prisma relation)
  fileName         String
  originalFilename String?
  fileSize         Int
  mimeType         String
  storageKey       String   @default("")
  extractedText    String?  @db.Text
  parsedData       Json?
  // Additive structured facets derived at parse time from the REAL parsed text +
  // enriched output (see lib/projects-tags.ts). projects = [{ name, description,
  // technologies[] }] pulled from an actual "Projects" section; tags = flat deduped
  // facet list (canonical skills + certs + languages + format). Honest-empty ([])
  // when the resume has no such content — never fabricated.
  projects         Json     @default("[]")
  tags             String[] @default([])
  parseStatus      String   @default("PENDING")
  parsedAt         DateTime?
  bulkUploadId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([bulkUploadId])
}

model BulkUpload {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String
  requisitionId   String?
  status          BulkUploadStatus @default(QUEUED)
  // Archive-ingest lifecycle (loose-file bulk leaves phase at its default):
  //   extracting → review → committing → done | failed
  phase           String           @default("extracting")
  archiveName     String?
  totalFiles      Int
  processedFiles  Int              @default(0)
  failedFiles     Int              @default(0)
  // Archive staging counters (per BulkImportItem lifecycle)
  extractedCount  Int              @default(0)
  pendingCount    Int              @default(0)
  approvedCount   Int              @default(0)
  rejectedCount   Int              @default(0)
  committedCount  Int              @default(0)
  errors          Json             @default("[]")
  createdAt       DateTime         @default(now())
  completedAt     DateTime?

  @@index([tenantId, status])
}

// Archive-ingest staging row. One per file extracted from an uploaded .zip.
// Holds the full extracted text so commit does NOT re-extract; a recruiter
// reviews/edits/approves these before any real Candidate/Resume is created.
model BulkImportItem {
  id            String   @id @default(uuid())
  tenantId      String
  bulkUploadId  String
  fileName      String
  mimeType      String
  sizeBytes     Int      @default(0)
  detectedName  String?
  detectedEmail String?
  textSnippet   String?
  extractedText String?  @db.Text
  // extracted | ocr_empty | failed | unsupported
  extractStatus String   @default("extracted")
  // WHY this item failed/was skipped, persisted per item so the batch result
  // reports the real reason each bad file was quarantined (corrupt PDF, unsupported
  // type, blank OCR, extraction error). Null for a clean "extracted" item. The
  // batch NEVER aborts on a bad file — it stages it with this reason instead.
  quarantineReason String?
  // pending | approved | rejected
  reviewStatus  String   @default("pending")
  // ATS score (0-100) of this resume against the BulkUpload's requisition, set
  // by the bulk-archive-extract worker after a service-to-service screen.
  // Null when the BulkUpload has no requisitionId (unranked import).
  score         Float?
  // null/"pending" (not yet scored) | "scored" | "failed". Never fabricated.
  scoreStatus   String?
  candidateId   String?
  createdAt     DateTime @default(now())

  @@index([bulkUploadId])
  @@index([tenantId])
}

// Local AgentRun projection — populated from runtime persistRun hook
model AgentRun {
  id                String   @id
  tenantId          String
  agentType         String
  status            String
  inputHash         String
  tokensIn          Int
  tokensOut         Int
  costUsd           Decimal  @db.Decimal(10, 6)
  latencyMs         Int
  modelName         String
  triggeredByUserId String?
  errorMessage      String?
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
}
