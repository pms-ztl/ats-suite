generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("BILLING_DATABASE_URL")
}

// Tenant.plan is mirrored here so we can gate without a sync HTTP call to
// tenant-service. tenant-service publishes tenant.plan.changed via NATS and
// our subscriber keeps this in sync.
model TenantPlanCache {
  tenantId  String   @id
  plan      String // mirrors TenantPlan enum
  updatedAt DateTime @updatedAt
}

// Per-tenant agent kill-switches (tenant admin can toggle agents off even
// if their plan allows them).
model AgentKillSwitch {
  id        String   @id @default(uuid())
  tenantId  String
  agentType String // "resume-parser", "candidate-screener", ...
  disabled  Boolean  @default(false)
  reason    String?
  updatedAt DateTime @updatedAt

  @@unique([tenantId, agentType])
  @@index([tenantId])
}

// Per-tenant agent execution log — denormalized for fast cost queries.
// Source-of-truth still lives in each agent-running service; this is a
// projection populated by NATS agent.completed subscriber.
model AgentRunCost {
  id                String   @id @default(uuid())
  tenantId          String
  agentRunId        String   @unique
  agentType         String
  status            String
  tokensIn          Int
  tokensOut         Int
  costUsd           Decimal  @db.Decimal(10, 6)
  latencyMs         Int
  // Optional — populated by ai-engine snapshot.modelName (e.g.
  // claude-sonnet-4-20250514, stub-deterministic). Drives the
  // real-vs-stub split + model cost charts on the AI ops dashboard.
  modelName         String?
  iterations        Int?
  triggeredByUserId String?
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, agentType])
  @@index([modelName])
}

// Per-tenant feature flags (separate from plan-based gating — used for
// gradual rollouts).
model FeatureFlag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  enabled   Boolean  @default(false)
  metadata  Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

// WF3 (modular platform) — PLATFORM-GLOBAL catalog of installable modules.
// One row per module the platform ships (no tenantId — like
// PlatformAgentKillSwitch). Read via prismaAdmin; never RLS'd. A module is
// switched ON for a tenant by creating a TenantModule row below; the manifest
// here is the static definition (capabilities, routes, plan requirement).
model ModuleRegistry {
  id             String   @id @default(uuid())
  key            String   @unique // stable module key, e.g. "assessments", "video-interviews"
  name           String
  version        String
  category       String
  type           String
  // When set, the tenant's plan must include this for the module to be enabled.
  // Null means available on every plan.
  requiresPlan   String?
  manifest       Json
  defaultEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// WF3 (modular platform) — per-tenant enablement + config for a module.
// Sibling of the dormant FeatureFlag (same tenant-scoped shape). RLS'd with
// the standard tenant_isolation policy so a tenant only sees its own modules.
model TenantModule {
  id        String    @id @default(uuid())
  tenantId  String
  moduleKey String // references ModuleRegistry.key (platform-global, no FK)
  enabled   Boolean   @default(false)
  config    Json      @default("{}")
  enabledAt DateTime?
  updatedBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// Phase 21 — platform-wide kill switch. When `disabled = true` for an
// agentType, ai-engine refuses to invoke that agent for ANY tenant. Used
// for emergency stop (bad prompts shipped, model regression, billing
// runaway) — gives super-admin one-click control over the whole fleet.
//
// This is DIFFERENT from AgentKillSwitch (per-tenant). Both gates run;
// the agent is allowed only if both gates allow it.
model PlatformAgentKillSwitch {
  agentType       String   @id // "resume-parser", "candidate-screener", ...
  disabled        Boolean  @default(false)
  reason          String? // surfaced to engineers in the audit + the API response
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
}

// Phase 22 — audit log of every platform-wide kill switch flip. Unlike
// PlatformAgentKillSwitch (one row per agent, overwritten on each change),
// this is append-only — every toggle creates a new row. Powers the
// "who killed what and why" audit viewer at /admin/platform/audit.
//
// Why a separate table: rolling back the kill switch shouldn't lose the
// history of "we killed this on Tuesday because of incident X". Without
// this, super-admin's only record of an action is the current state.
model PlatformKillAudit {
  id          String   @id @default(uuid())
  agentType   String
  disabled    Boolean // the new state set by this action
  reason      String?
  actorUserId String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([agentType, createdAt])
}

// Phase 30 — Stripe subscription mirror.
// Stripe is the source of truth for subscription state (created via Checkout,
// updated via webhooks). We mirror just enough here to:
//   1. Show the current period end + cancel-at-period-end flag in the UI
//   2. Surface stripeCustomerId for the Customer Portal link
//   3. Roll back to FREE when status flips to past_due / canceled / unpaid
//
// On webhook events we upsert this row, then publish tenant.plan.changed so
// the rest of the platform (tenant-service, gating logic) stays in sync. Plan
// is also written to TenantPlanCache for the existing fast-gate path.
model StripeSubscription {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String   @unique
  // Plan derived from the Stripe price ID -> looked up in STRIPE_PRICE_TO_PLAN
  plan                 String // "STARTER" | "PROFESSIONAL"
  status               String // active | past_due | canceled | unpaid | trialing | incomplete
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  // For self-service downgrades we need to remember the price the user is on.
  stripePriceId        String
  // Audit
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
}

// Phase 30 — append-only webhook event log so we can debug subscription state
// transitions in production. Stripe webhooks are eventually consistent and we
// occasionally need to replay one — keeping the raw payload here makes that
// trivial.
model StripeWebhookEvent {
  id              String    @id // Stripe's evt_xxx id (used for idempotency)
  type            String // e.g. "customer.subscription.updated"
  tenantId        String? // set when we can match the event to a tenant
  livemode        Boolean
  payload         Json // full event.data.object for replay
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime  @default(now())

  @@index([type, createdAt])
  @@index([tenantId, createdAt])
}

// Phase 21 — central prompt overrides. When a row exists for an agentType
// with `isActive = true`, ai-engine uses these values instead of the
// hardcoded defaults baked into the agent definitions. Cached for 5
// minutes in ai-engine so a stampede of agent calls doesn't hammer the DB.
//
// Version history is preserved by leaving inactive rows in place — each
// PUT creates a new row, marks the previous active row inactive. Lets
// super-admin roll back to a known-good prompt by toggling `isActive`.
model PromptOverride {
  id              String   @id @default(uuid())
  agentType       String
  // Override fields — null means "use the default for this field". Lets
  // super-admin tweak just the temperature without rewriting the whole prompt.
  systemPrompt    String?  @db.Text
  modelName       String?
  temperature     Float?
  // Audit + rollback support.
  version         Int      @default(1)
  isActive        Boolean  @default(true)
  notes           String? // why was this saved (changelog entry)
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([agentType, isActive])
  @@index([agentType, createdAt])
}
