generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("JOB_DATABASE_URL")
}

enum RequisitionStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CLOSED
  CANCELLED
}

model Requisition {
  id              String            @id @default(uuid())
  tenantId        String
  title           String
  department      String
  location        String
  country         String            @default("US")
  jobFamily       String?
  description     String?
  requirements    Json              @default("[]")
  salaryMin       Float?
  salaryMax       Float?
  salaryCurrency  String            @default("USD")
  status          RequisitionStatus @default(DRAFT)
  priority        Int               @default(3)
  hiringManagerId String? // FK to identity-service User
  recruiterId     String? // FK to identity-service User
  headcount       Int               @default(1)
  targetStartDate DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  closedAt        DateTime?

  jobPostings JobPosting[]
  formSchema  ApplicationFormSchema?

  @@index([tenantId])
  @@index([tenantId, status])
}

model JobPosting {
  id               String    @id @default(uuid())
  tenantId         String
  requisitionId    String
  slug             String
  title            String
  description      String    @db.Text
  requirements     String[]  @default([])
  isPublished      Boolean   @default(false)
  publishedAt      DateTime?
  expiresAt        DateTime?
  views            Int       @default(0)
  applicationCount Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  requisition Requisition @relation(fields: [requisitionId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
}

model ApplicationFormSchema {
  id            String   @id @default(uuid())
  tenantId      String
  requisitionId String   @unique
  name          String   @default("Default")
  fields        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requisition Requisition @relation(fields: [requisitionId], references: [id])

  @@index([tenantId])
}

model Skill {
  id        String   @id @default(uuid())
  tenantId  String? // null = global / platform-managed
  name      String
  category  String?
  parentId  String?
  aliases   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Skill?  @relation("SkillHierarchy", fields: [parentId], references: [id])
  children Skill[] @relation("SkillHierarchy")

  @@unique([tenantId, name])
  @@index([tenantId])
}
