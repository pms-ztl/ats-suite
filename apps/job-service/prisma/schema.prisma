generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("JOB_DATABASE_URL")
}

enum RequisitionStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CLOSED
  CANCELLED
}

// WF-E: lifecycle of a single (jobPosting, board) distribution. Mirrors the
// real-data-or-null discipline of the assessment-provider axis: status only
// advances on a real adapter response; externalPostingId/externalUrl stay null
// until the board returns them. PENDING_PARTNER_APPROVAL covers boards that
// queue a posting for manual partner review before it goes live.
enum DistributionStatus {
  PENDING
  POSTING
  ACTIVE
  FAILED
  EXPIRED
  CLOSED
  PENDING_PARTNER_APPROVAL
}

model Requisition {
  id              String            @id @default(uuid())
  tenantId        String
  title           String
  department      String
  location        String
  country         String            @default("US")
  jobFamily       String?
  description     String?
  requirements    Json              @default("[]")
  customFields    Json              @default("[]")
  // Module A — ordered eligibility rules (EligibilityRule[] from @cdc-ats/contracts)
  // evaluated against the candidate's submitted answers on the public apply path.
  // A failing rule short-circuits the apply with its own errorMessage. Empty = open.
  eligibilityRules Json             @default("[]")
  salaryMin       Float?
  salaryMax       Float?
  salaryCurrency  String            @default("USD")
  status          RequisitionStatus @default(DRAFT)
  priority        Int               @default(3)
  hiringManagerId String?           // FK to identity-service User
  recruiterId     String?           // FK to identity-service User
  headcount       Int               @default(1)
  targetStartDate DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  closedAt        DateTime?

  jobPostings    JobPosting[]
  formSchema     ApplicationFormSchema?

  @@index([tenantId])
  @@index([tenantId, status])
}

model JobPosting {
  id               String    @id @default(uuid())
  tenantId         String
  requisitionId    String
  slug             String
  title            String
  description      String    @db.Text
  requirements     String[]  @default([])
  isPublished      Boolean   @default(false)
  publishedAt      DateTime?
  expiresAt        DateTime?
  views            Int       @default(0)
  applicationCount Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  requisition           Requisition            @relation(fields: [requisitionId], references: [id])
  jobBoardDistributions JobBoardDistribution[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
}

model ApplicationFormSchema {
  id            String   @id @default(uuid())
  tenantId      String
  requisitionId String   @unique
  name          String   @default("Default")
  fields        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requisition Requisition @relation(fields: [requisitionId], references: [id])

  @@index([tenantId])
}

// Module A — College / CDC partner. A campus the tenant shares a job link with.
// The shareToken yields a public landing (/cdc/<token>) listing the tenant's open
// roles; every application made through it is stamped with this college's name so
// resumes arrive WITH the college attached and recruiters can group by campus.
model CollegePartner {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  slug           String
  shareToken     String   @unique
  contactEmail   String?
  // Optional restriction: only these requisition ids are shown on the landing.
  requisitionIds String[] @default([])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Skill {
  id          String   @id @default(uuid())
  tenantId    String?  // null = global / platform-managed
  name        String
  category    String?
  parentId    String?
  aliases     String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Skill?  @relation("SkillHierarchy", fields: [parentId], references: [id])
  children Skill[] @relation("SkillHierarchy")

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Transactional outbox — see @cdc-ats/outbox for usage. Events get written
// here in the same transaction as the domain change, then a background
// worker publishes to NATS with at-least-once guarantee.
enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

model Outbox {
  id           String       @id @default(uuid())
  subject      String       // NATS subject, e.g. tenant.{id}.agent.completed
  type         String       // logical event type, e.g. agent.completed
  tenantId     String?      // null for platform-wide events
  payload      Json
  status       OutboxStatus @default(PENDING)
  attemptCount Int          @default(0)
  lastError    String?
  sentAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([tenantId])
}

// Per-service AgentRun — denormalized telemetry for job-service agent calls
// (jd-author). billing-service aggregates across all services via NATS events.
model AgentRun {
  id                String   @id
  tenantId          String
  agentType         String
  status            String
  inputHash         String
  tokensIn          Int
  tokensOut         Int
  costUsd           Decimal  @db.Decimal(10, 6)
  latencyMs         Int
  modelName         String
  iterations        Int      @default(1)
  triggeredBy       String?  // userId or "system"
  errorMessage      String?
  startedAt         DateTime
  completedAt       DateTime
  createdAt         DateTime @default(now())

  @@index([tenantId, createdAt])
}

// WF-E: one row per (jobPosting, board) syndication target. The hiring-platform
// adapter axis (job boards / multiposting partners) is DISTINCT from the
// assessment-provider axis. HARD RULES: externalPostingId/externalUrl/status are
// real-data-or-null, never synthesized; they are populated ONLY from a real
// adapter response, with the verbatim vendor payload kept in `raw`. There is no
// auto-reject; lastError captures a real adapter/transport failure.
model JobBoardDistribution {
  id                String             @id @default(uuid())
  tenantId          String
  jobPostingId      String
  board             String
  externalPostingId String?
  externalUrl       String?
  status            DistributionStatus @default(PENDING)
  lastError         String?
  lastSyncedAt      DateTime?
  raw               Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id])

  @@unique([tenantId, jobPostingId, board])
  @@index([tenantId])
  @@index([board, status])
}

// WF-E + WF-I: idempotency ledger AND live ingest-pipeline tracker for the public
// application intake.
//
// Idempotency (WF-E): keyed by the caller-supplied Idempotency-Key per tenant so a
// retried (or duplicated) apply POST replays the original response instead of
// creating a second Candidate / Application. The accept step is "finished" once
// responseCode + responseBody are set; a fresh lockedAt guards concurrent retries;
// recoveryPoint tracks how far a partially-completed request got so an interrupted
// write can resume.
//
// Pipeline tracking (WF-I / I2-I4): once the accept-fast path has created the
// Candidate + Application it records the applicationId here and uses ingestStage to
// carry the REAL staged-ingest progress (PENDING_INGEST -> SCANNED -> PARSED ->
// SCREENED, or REJECTED). The apply-ingest worker (I3) advances ingestStage by
// applicationId; the status route (I4) reads it by applicationId. ingestStage is a
// plain string, NOT the candidate-service ApplicationStatus enum (which stays
// ACTIVE), so the pipeline stage never collides with the application lifecycle.
// ingestStage is null + never fabricated ahead of the real stage.
model ApplicationIdempotency {
  id             BigInt   @id @default(autoincrement())
  tenantId       String
  idempotencyKey String
  requestMethod  String
  requestPath    String
  responseCode   Int?
  responseBody   Json?
  recoveryPoint  String   @default("started")
  applicationId  String?
  // Correlation keys for the async pipeline (WF-I / I3). The resume.parsed /
  // screening.completed events carry candidateId (+ requisitionId for screening)
  // but no applicationId, so the apply-ingest NATS subscriber resolves THIS row by
  // (tenantId, candidateId, requisitionId) to advance ingestStage to PARSED /
  // SCREENED. Null on the legacy multipart path (which never touches this ledger).
  candidateId    String?
  requisitionId  String?
  ingestStage    String?
  ingestError    String?
  lockedAt       DateTime?
  createdAt      DateTime @default(now())
  lastRunAt      DateTime?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, applicationId])
  @@index([tenantId, candidateId, requisitionId])
  @@index([tenantId, createdAt])
}

// WF-E: per-tenant bearer token for the public job feed (XML/JSON board feed).
// One token per tenant; rotating it issues a new row's token. The feed endpoint
// resolves the owning tenant from this token with no auth context (admin client).
model JobFeedToken {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  token     String   @unique
  createdAt DateTime @default(now())
}

