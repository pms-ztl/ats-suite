generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("IDENTITY_DATABASE_URL")
}

// ── Identity-service local read model of UserRole.
// Mirrors @cdc-ats/contracts UserRoleSchema. Single source of truth at
// the Zod level — Prisma enum exists only so the column type is constrained.
enum UserRole {
  SUPER_ADMIN
  ADMIN
  RECRUITER
  HIRING_MANAGER
  COMPLIANCE_OFFICER
  INTERVIEWER
  CANDIDATE
}

model User {
  id              String    @id @default(uuid())
  tenantId        String // FK semantically to tenant-service's Tenant.id, but NO Prisma relation (cross-service)
  email           String
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole  @default(RECRUITER)
  department      String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  // TOTP MFA — opt-in per user. Secret is base32 (32 chars); only set
  // when the user completes the enrolment flow + verifies one code.
  mfaSecret       String?
  mfaEnabled      Boolean   @default(false)
  // Phase 28 — SSO: stable IdP-provided identifier (SAML nameID, OIDC sub).
  // When set, this user authenticated via SSO last time. Unique across
  // tenants because real-world IdPs guarantee uniqueness per IdP.
  externalId      String?   @unique
  ssoLastLogin    DateTime?
  // Phase 31b — set true after the user clicks the link in the verify
  // email sent after /register-company. Existing users (created before
  // Phase 31b) keep their default of true to avoid retroactively locking
  // anyone out — the migration backfills emailVerified=true for them.
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inviteTokens       InviteToken[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([externalId])
}

// Phase 31b — email verification tokens. Created by /register-company and
// /resend-verification. Consumed by /verify-email. Single-use, 24h expiry
// (longer than password resets — users often don't see the email for hours).
model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  email     String // snapshot — guards against an attacker changing the
  // user's email between request + click
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// Password reset request — created by /auth/forgot-password, consumed by
// /auth/reset-password. Tokens are single-use, expire after 1h.
model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model InviteToken {
  id              String    @id @default(uuid())
  tenantId        String
  email           String
  role            UserRole  @default(RECRUITER)
  token           String    @unique @default(uuid())
  expiresAt       DateTime
  usedAt          DateTime?
  invitedByUserId String
  createdAt       DateTime  @default(now())

  invitedBy User @relation(fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([token])
}

// Local audit trail for identity events (logins, role changes, invites).
// Other services keep their own audit trails; the gateway can aggregate.
model AuditEvent {
  id           String   @id @default(uuid())
  tenantId     String?
  actorUserId  String?
  action       String // "USER_LOGIN", "USER_INVITED", "USER_ROLE_CHANGED", ...
  resourceType String
  resourceId   String
  metadata     Json     @default("{}")
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId])
}

// ── Phase 28 — Enterprise SSO ──────────────────────────────────────────────

enum SsoProtocol {
  SAML
  OIDC
}

enum SsoStatus {
  DRAFT
  ENABLED
  DISABLED
}

// Per-tenant SSO config. One row per tenant max.
// Status flow: DRAFT (test login only, no real provisioning) → ENABLED
// (full provisioning + login) → DISABLED (config retained but rejected).
model TenantSso {
  id       String      @id @default(uuid())
  tenantId String      @unique
  protocol SsoProtocol
  status   SsoStatus   @default(DRAFT)

  // SAML 2.0 config (null when protocol = OIDC)
  samlEntryPoint  String? // IdP SSO URL where we send AuthnRequest
  samlIssuer      String? // Our entity ID (auto-derived from tenant slug)
  samlCertificate String? @db.Text // IdP signing cert PEM (validates assertions)

  // OIDC config (null when protocol = SAML)
  oidcIssuerUrl    String? // e.g. https://accounts.google.com — used for IdP discovery
  oidcClientId     String?
  oidcClientSecret String? @db.Text // stored plaintext in dev; KMS-encrypted in prod (Phase 32)

  // Common: which email domains route here for /sso/discover
  emailDomains String[] @default([]) // e.g. ["hcl.com", "hcltech.com"]

  // IdP claim names — defaults match Okta/Workspace/Azure AD common shapes
  attrEmail     String @default("email")
  attrFirstName String @default("firstName")
  attrLastName  String @default("lastName")
  attrGroups    String @default("groups")

  // Role mapping: {IdP group value → our UserRole}
  // Default (no group match) lands in defaultRole.
  roleMap     Json     @default("{}")
  defaultRole UserRole @default(RECRUITER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Append-only audit of every SSO login attempt. Powers the /settings/sso
// audit panel + feeds platform security telemetry.
model SsoLoginAudit {
  id        String      @id @default(uuid())
  tenantId  String
  email     String
  protocol  SsoProtocol
  outcome   String // "success" | "fail:bad_signature" | "fail:no_email" | ...
  ipAddress String?
  userAgent String?
  userId    String? // populated when user found/created
  createdAt DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([email, createdAt])
}
