{
  "name": "@cdc-ats/identity-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@cdc-ats/common": "*",
    "@cdc-ats/contracts": "*",
    "@node-saml/passport-saml": "^5.1.0",
    "@prisma/client": "^6.0.0",
    "argon2": "^0.41.1",
    "express": "^4.21.2",
    "openid-client": "^6.8.4",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/passport": "^1.0.17",
    "@types/qrcode": "^1.5.5",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
