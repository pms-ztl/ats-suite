generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("IDENTITY_DATABASE_URL")
}

// ── Identity-service local read model of UserRole.
// Mirrors @cdc-ats/contracts UserRoleSchema. Single source of truth at
// the Zod level — Prisma enum exists only so the column type is constrained.
enum UserRole {
  SUPER_ADMIN
  ADMIN
  RECRUITER
  HIRING_MANAGER
  COMPLIANCE_OFFICER
  INTERVIEWER
  CANDIDATE
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   // FK semantically to tenant-service's Tenant.id, but NO Prisma relation (cross-service)
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(RECRUITER)
  department   String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  // TOTP MFA — opt-in per user. Secret is base32 (32 chars); only set
  // when the user completes the enrolment flow + verifies one code.
  mfaSecret    String?
  mfaEnabled   Boolean  @default(false)
  // Phase 28 — SSO: stable IdP-provided identifier (SAML nameID, OIDC sub).
  // When set, this user authenticated via SSO last time. Unique across
  // tenants because real-world IdPs guarantee uniqueness per IdP.
  externalId   String?  @unique
  ssoLastLogin DateTime?
  // Phase 31b — set true after the user clicks the link in the verify
  // email sent after /register-company. Existing users (created before
  // Phase 31b) keep their default of true to avoid retroactively locking
  // anyone out — the migration backfills emailVerified=true for them.
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Phase 35 — self-referential org hierarchy. The user's direct manager
  // (another User.id in the SAME tenant). null = top of the tenant tree (the
  // tenant admin). Modeled as a plain scalar (NO Prisma relation/FK) so that
  // FORCE-RLS inserts and the admin-client seed never trip a self-FK
  // referential check; the manager/report tree is resolved in app code.
  managerId    String?

  inviteTokens InviteToken[]
  passwordResets PasswordReset[]
  emailVerifications EmailVerification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([externalId])
  @@index([managerId])
}

// Phase 34b — per-tenant API keys for the public ingest API.
//
// Tenants generate one or more keys (via /settings/api-keys) and hand them
// to external systems (job boards, the Chrome extension, scripts). Every
// request to /api/v1/* carries Authorization: Bearer <key>.
//
// Security:
//   - Only the prefix (first 8 chars) is shown after creation; the full
//     key is shown ONCE at creation time and never again
//   - keyHash stores argon2id(key); we never store the plaintext
//   - revokedAt: when set, key is rejected immediately (no need to delete)
//   - lastUsedAt: updated on each successful auth so tenants can see
//     which keys are dormant
//   - Per-key rate-limit counters live in Redis (not in this schema)
model TenantApiKey {
  id           String    @id @default(uuid())
  tenantId     String
  name         String    @db.VarChar(80)        // human label, e.g. "LinkedIn extension"
  keyPrefix    String                            // first 8 chars of plaintext, e.g. "ats_abcd"
  keyHash      String                            // argon2id hash of the full plaintext key
  createdByUserId String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  // Scopes — array of strings like "candidates:write". Empty = no permission.
  // For v1 we ship one scope "candidates:write"; future-proofing the column.
  scopes       String[]  @default([])

  @@index([tenantId, revokedAt])
  @@index([keyPrefix])
}

// Phase 31b — email verification tokens. Created by /register-company and
// /resend-verification. Consumed by /verify-email. Single-use, 24h expiry
// (longer than password resets — users often don't see the email for hours).
model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  email     String    // snapshot — guards against an attacker changing the
                      // user's email between request + click
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// Password reset request — created by /auth/forgot-password, consumed by
// /auth/reset-password. Tokens are single-use, expire after 1h.
model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model InviteToken {
  id        String    @id @default(uuid())
  tenantId  String
  email     String
  role      UserRole  @default(RECRUITER)
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  invitedByUserId String
  createdAt DateTime  @default(now())

  invitedBy User @relation(fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([token])
}

// Local audit trail for identity events (logins, role changes, invites).
// Other services keep their own audit trails; the gateway can aggregate.
model AuditEvent {
  id           String   @id @default(uuid())
  tenantId     String?
  actorUserId  String?
  action       String   // "USER_LOGIN", "USER_INVITED", "USER_ROLE_CHANGED", ...
  resourceType String
  resourceId   String
  metadata     Json     @default("{}")
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId])
}

// ── Phase 28 — Enterprise SSO ──────────────────────────────────────────────

enum SsoProtocol {
  SAML
  OIDC
}

enum SsoStatus {
  DRAFT
  ENABLED
  DISABLED
}

// Per-tenant SSO config. One row per tenant max.
// Status flow: DRAFT (test login only, no real provisioning) → ENABLED
// (full provisioning + login) → DISABLED (config retained but rejected).
model TenantSso {
  id              String       @id @default(uuid())
  tenantId        String       @unique
  protocol        SsoProtocol
  status          SsoStatus    @default(DRAFT)

  // SAML 2.0 config (null when protocol = OIDC)
  samlEntryPoint  String?      // IdP SSO URL where we send AuthnRequest
  samlIssuer      String?      // Our entity ID (auto-derived from tenant slug)
  samlCertificate String?      @db.Text  // IdP signing cert PEM (validates assertions)

  // OIDC config (null when protocol = SAML)
  oidcIssuerUrl    String?     // e.g. https://accounts.google.com — used for IdP discovery
  oidcClientId     String?
  oidcClientSecret String?     @db.Text  // stored plaintext in dev; KMS-encrypted in prod (Phase 32)

  // Common: which email domains route here for /sso/discover
  emailDomains    String[]     @default([])  // e.g. ["hcl.com", "hcltech.com"]

  // IdP claim names — defaults match Okta/Workspace/Azure AD common shapes
  attrEmail       String       @default("email")
  attrFirstName   String       @default("firstName")
  attrLastName    String       @default("lastName")
  attrGroups      String       @default("groups")

  // Role mapping: {IdP group value → our UserRole}
  // Default (no group match) lands in defaultRole.
  roleMap         Json         @default("{}")
  defaultRole     UserRole     @default(RECRUITER)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
}

// Append-only audit of every SSO login attempt. Powers the /settings/sso
// audit panel + feeds platform security telemetry.
model SsoLoginAudit {
  id          String       @id @default(uuid())
  tenantId    String
  email       String
  protocol    SsoProtocol
  outcome     String       // "success" | "fail:bad_signature" | "fail:no_email" | ...
  ipAddress   String?
  userAgent   String?
  userId      String?      // populated when user found/created
  createdAt   DateTime     @default(now())

  @@index([tenantId, createdAt])
  @@index([email, createdAt])
}

// ── WF3 / Slice C2 — configurable dashboards + per-user UI prefs ────────────

// A persisted dashboard layout document. Two flavours, distinguished by userId:
//   - userId = NULL  → a tenant-default / system row (the layout a user inherits
//     when they have no personal override). scope describes who it applies to.
//   - userId = <id>  → that user's personal saved layout for a dashboardKey.
// The `document` JSON holds the widget grid (positions, sizes, widget configs);
// schemaVersion lets the renderer migrate older documents. Additive: existing
// rows are unaffected because this is a brand-new table.
model DashboardLayout {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String?  // NULL = tenant-default / system row; else owning user
  scope        String   // e.g. "tenant" | "role:RECRUITER" | "user"
  dashboardKey String   @default("home") // which dashboard surface this targets
  name         String
  document     Json     // widget grid + per-widget config
  schemaVersion Int     @default(1)
  isDefault    Boolean  @default(false)
  updatedBy    String   // userId of whoever last saved it
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, userId, dashboardKey])
  @@index([tenantId, scope])
}

// Per-user UI preferences (theme, density, locale, accent). One row per user.
// prefs is an open JSON bag for forward-compatible flags so we never have to
// migrate for a new toggle. Additive: brand-new table.
model UserUiPrefs {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String   @unique
  colorMode      String   @default("system")      // "system" | "light" | "dark"
  density        String   @default("comfortable")  // "comfortable" | "compact"
  locale         String?
  timezone       String?
  accentOverride String?
  prefs          Json     @default("{}")
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}
