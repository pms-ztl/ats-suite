    "start:standalone": "node .next/standalone/apps/frontend/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next .turbo",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.ts"
