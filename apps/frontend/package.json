    "build": "next build && npm run postbuild:standalone",
    "postbuild:standalone": "rimraf .next/standalone/apps/frontend/.next/static .next/standalone/apps/frontend/public && shx cp -r .next/static .next/standalone/apps/frontend/.next/static && shx cp -r public .next/standalone/apps/frontend/public",
