generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("NOTIFICATION_DATABASE_URL")
}

enum NotificationType {
  PLAN_CHANGE_REQUESTED
  PLAN_CHANGE_APPROVED
  PLAN_CHANGE_REJECTED
  NEW_TENANT_SIGNUP
  BULK_UPLOAD_COMPLETED
  SEAT_LIMIT_REACHED
  INTERVIEW_FEEDBACK_NEW
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  // tenantId NULL = platform-wide (super-admin only sees these)
  tenantId  String?
  // userId NULL = broadcast to all users in tenant (or all super-admins if tenantId null)
  userId    String?
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  metadata  Json             @default("{}")
  // Which channels should this be delivered through.
  // Values: "in_app" (always — DB + SSE), "email", "slack".
  channels  String[]         @default(["in_app"])
  createdAt DateTime         @default(now())

  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

enum DeliveryChannel {
  IN_APP
  EMAIL
  SLACK
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

// One row per notification × channel attempt. Lets us retry failures
// + show per-notification delivery state in the UI.
model NotificationDelivery {
  id             String          @id @default(uuid())
  notificationId String
  tenantId       String?
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  recipient      String          // email address, Slack channel, or userId for in_app
  attemptCount   Int             @default(0)
  lastError      String?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status, channel])
  @@index([tenantId, createdAt])
}

// ── HITL (Human-In-The-Loop) checkpoints ──────────────────────────────
// Created when an agent run requests human review (low confidence,
// bias detected, plan limit exceeded, sensitive decision).
// Surfaced in the /hitl review queue. Tenant admin approves or rejects.
enum HitlStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model HitlCheckpoint {
  id            String     @id @default(uuid())
  tenantId      String
  agentRunId    String
  agentType     String     // e.g. "candidate-screener", "bias-auditor"
  type          String     // "low_confidence", "bias_flag", "sensitive_decision"
  action        String     // short title shown in queue ("Approve screening", etc.)
  payload       Json       @default("{}")    // agent output + context the reviewer needs
  status        HitlStatus @default(PENDING)
  slaMinutes    Int        @default(240)     // 4 hours default
  assignedTo    String?    // optional userId
  assignedToName String?
  resolution    Json?      // {action, comment, ...}
  resolvedBy    String?
  resolvedAt    DateTime?
  escalatedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([agentRunId])
}

// Per-tenant integration config (Slack webhook URL, SMTP sender override).
// In prod, treat the encrypted form as secrets-backed; for dev we plaintext-store.
model TenantIntegration {
  id        String   @id @default(uuid())
  tenantId  String
  kind      String   // "slack" | "email"
  config    Json     // {webhookUrl: "..."} for slack; {fromAddress: "..."} for email
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, kind])
  @@index([tenantId])
}

// Per-tenant override of the default email body for a given notification type.
// When rendering an email, mailer first looks up (tenantId, type) here;
// if no row exists, it falls back to the system default in renderNotificationEmail.
// `bodyHtml` and `bodyText` support Mustache-lite variables: {{candidateName}}, etc.
// `variables` is a documentation column listing the variables this template
// expects — used by the frontend editor to render a variable picker.
model EmailTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  type        String   // matches NotificationType enum value
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String   @db.Text
  variables   Json     @default("[]")  // ["candidateName", "jobTitle", ...]
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId])
}

// Phase 34e — SMS / WhatsApp apply conversation state.
//
// One row per (tenantId, fromNumber) — tracks where this applicant is in
// the multi-turn flow. Conversations time out after 24h of inactivity
// (worker prunes; we just check completedAt + updatedAt in queries).
//
// Flow:
//   step=GREETING    → we sent the welcome, waiting for name
//   step=AWAITING_NAME → got first message, asked for full name
//   step=AWAITING_EMAIL → got name, asked for email
//   step=AWAITING_RESUME → got email, asked them to text resume URL
//   step=COMPLETED   → candidate created
enum SmsConvoStep {
  GREETING
  AWAITING_NAME
  AWAITING_EMAIL
  AWAITING_RESUME
  COMPLETED
}

model SmsConversation {
  id           String         @id @default(uuid())
  tenantId     String
  fromNumber   String                                  // E.164 format
  toNumber     String                                  // our Twilio number for this tenant
  channel      String                                  // "sms" | "whatsapp"
  step         SmsConvoStep   @default(GREETING)
  collectedName  String?
  collectedEmail String?
  collectedResumeUrl String?
  candidateId  String?                                 // set when conversation completes
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([tenantId, fromNumber])
  @@index([tenantId, completedAt])
}

// Phase 32b — in-app support tickets.
//
// Tenants open tickets via /support; super-admins triage them via
// /admin/support. Replies are tracked in SupportTicketMessage for a
// threaded conversation. Status is intentionally a small set — anything
// resembling a full helpdesk (priorities, SLAs, assignees, custom fields)
// belongs in a real ticketing tool (Zendesk, Linear). This is here to
// make sure customers can reach us at all, not to replace those.

enum SupportTicketStatus {
  OPEN              // newly opened, waiting on us
  AWAITING_CUSTOMER // we replied, ball is in their court
  RESOLVED          // closed by either side
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id            String                 @id @default(uuid())
  tenantId      String                 // the tenant the ticket belongs to
  openedByUserId String                // the user who opened it
  openedByEmail String                 // snapshot — guards against the user being deleted later
  subject       String                 @db.VarChar(200)
  status        SupportTicketStatus    @default(OPEN)
  priority      SupportTicketPriority  @default(NORMAL)
  category      String?                @db.VarChar(60)  // optional free-text bucket (billing / bug / question)
  resolvedAt    DateTime?
  resolvedByUserId String?             // super-admin who marked it resolved
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  messages      SupportTicketMessage[]

  @@index([tenantId, status])
  @@index([status, createdAt])
}

model SupportTicketMessage {
  id          String        @id @default(uuid())
  ticketId    String
  // authorRole = "CUSTOMER" or "SUPPORT" — kept as a string (not enum) so
  // it survives a future role-rename without a schema migration.
  authorRole  String
  authorUserId String
  authorEmail String
  body        String        @db.Text
  isInternal  Boolean       @default(false)  // super-admin "internal note" not visible to customer
  createdAt   DateTime      @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// Phase 40 — outbound webhooks: tenants register URLs to receive domain events
// (candidate.*, screening.*, interview.*, ...) signed with HMAC-SHA256.
model Webhook {
  id             String    @id @default(uuid())
  tenantId       String
  url            String
  secret         String                     // HMAC signing secret (shown once on create)
  events         String[]  @default([])     // subscribed event types; empty = all
  active         Boolean   @default(true)
  failureCount   Int       @default(0)
  lastStatus     Int?
  lastDeliveryAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([tenantId])
}

// Phase 40 — immutable audit trail for SOC2/GDPR evidence. Append-only;
// records security- + decision-relevant events fanned in from NATS.
model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  action      String                       // e.g. "interview.scheduled", "plan-change.approved"
  actorUserId String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}

// ── In-app team messaging (tenant-isolated) ───────────────────────────────
// A Conversation, its participants, and its messages all carry tenantId and are
// RLS-protected, so a user can only ever see conversations in their own tenant.
// Cross-tenant messaging is impossible: a conversation lives in exactly one
// tenant, and RLS hides it from every other tenant's session.
model Conversation {
  id          String   @id @default(uuid())
  tenantId    String
  title       String?  // group title; null for 1:1
  isGroup     Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId, updatedAt])
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  tenantId       String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([tenantId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  tenantId       String
  senderId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId, createdAt])
}
