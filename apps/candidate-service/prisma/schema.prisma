generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("CANDIDATE_DATABASE_URL")
}

enum ApplicationStage {
  APPLIED
  SCREENED
  PHONE_SCREEN
  ASSESSMENT
  INTERVIEW
  FINAL_REVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum ApplicationStatus {
  ACTIVE
  ON_HOLD
  REJECTED
  WITHDRAWN
  HIRED
}

model Candidate {
  id          String   @id @default(uuid())
  tenantId    String
  email       String
  firstName   String
  lastName    String
  phone       String?
  location    String?
  country     String?
  resumeUrl   String?  // pointer to resume-service (internal://resume/{id})
  linkedinUrl String?
  portfolioUrl String?
  summary     String?
  source      String?
  tags        String[] @default([])
  isAnonymized Boolean @default(false)

  // Phase 35c + 37 — structured data backfilled from the resume parser.
  // Phase 35c shape (flat): skills[], experience[], education[], summary,
  // languages[], certifications[], links{}, parsedAt, sourceResumeId.
  // Phase 37 extends with: enriched skills (canonicalId, yearsActive,
  // lastUsedYear, depth, sourceProjectIndices), enriched experience
  // (companyCanonicalId, NormalizedDate dates, tenureMonths, achievements[]),
  // enriched education (schoolCanonicalId), honestyFlags[], formatGuess,
  // and githubCorroboration{} when a GitHub URL was extractable.
  // Backfilled by a NATS subscriber on resume.parsed.
  parsedSummary Json?

  // Phase 37j — fairness mode (PII-stripped derived view of parsedSummary).
  // Name nulled, contact redacted, location at country level, school +
  // university prestige stripped. Used by the search UI when the
  // "blind hiring" toggle is on. Computed once by the subscriber, not
  // re-derived per query (avoids drift + saves CPU).
  parsedSummaryFair Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
  notes        CandidateNote[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Application {
  id             String            @id @default(cuid())
  tenantId       String
  candidateId    String
  requisitionId  String            // FK to job-service Requisition (no Prisma relation, cross-service)
  stage          ApplicationStage  @default(APPLIED)
  status         ApplicationStatus @default(ACTIVE)
  appliedAt      DateTime          @default(now())
  stageUpdatedAt DateTime          @default(now())
  notes          String?
  formResponses  Json?             // custom form submissions
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  candidate    Candidate              @relation(fields: [candidateId], references: [id])
  attachments  ApplicationAttachment[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([candidateId])
  @@index([requisitionId])
}

model ApplicationAttachment {
  id            String   @id @default(uuid())
  tenantId      String
  applicationId String
  fieldId       String
  fileName      String
  originalName  String
  fileSize      Int
  mimeType      String
  storageKey    String
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
}

model CandidateNote {
  id          String   @id @default(uuid())
  tenantId    String
  candidateId String
  authorUserId String  // FK to identity-service User
  content     String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@index([tenantId])
  @@index([candidateId])
}

enum OfferStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

// Extends the pipeline past INTERVIEW into offer management. The AI
// offer-LETTER generator lives separately (agent-offer.ts); this is the
// plain offer RECORD that the Offers board reads + the approval flow updates.
model Offer {
  id            String      @id @default(uuid())
  tenantId      String
  candidateId   String
  requisitionId String      // FK to job-service Requisition (cross-service, no relation)
  applicationId String?
  baseSalary    Int
  currency      String      @default("USD")
  bonusPercent  Int?
  equity        String?
  startDate     DateTime?
  expiresAt     DateTime?
  status        OfferStatus @default(DRAFT)
  approvedBy    String?     // identity-service userId who approved
  // Module E — object-storage key of the rendered offer-letter PDF, set on
  // approve when storage is configured. NULL when storage is not wired up
  // (we never fabricate a key) or before approval.
  offerLetterKey String?
  acceptedAt    DateTime?   // when the candidate accepted the offer (Module E)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([candidateId])
}
