{
  "name": "cdc-ats-microservices",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.9.2",
  "description": "CDC ATS — 10-service microservices architecture (Phase 7 rewrite)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency 20",
    "dev:gateway": "turbo run dev --filter=@cdc-ats/api-gateway --filter=@cdc-ats/frontend",
    "dev:backend": "turbo run dev --concurrency 20 --filter=!@cdc-ats/frontend",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "infra:ps": "docker compose -f infra/docker-compose.yml ps",
    "stack:up": "npm run infra:up && npm run dev",
    "docker:build:all": "docker compose -f infra/docker-compose.full.yml build",
    "docker:up:all": "docker compose -f infra/docker-compose.full.yml up -d",
    "docker:down:all": "docker compose -f infra/docker-compose.full.yml down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
