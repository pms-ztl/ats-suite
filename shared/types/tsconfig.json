{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitReturns": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
