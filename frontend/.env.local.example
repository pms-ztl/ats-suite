# =============================================================================
# ATS Platform — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.
# Never commit .env.local to source control.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Base URL of the backend REST API (no trailing slash).
# In development this points to the local NestJS server (see backend/.env PORT).
# In production, set this to your deployed API origin.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Convenience alias used in some contexts as the root API origin (no /api path).
# Keep in sync with NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# When set to "true" the frontend skips real HTTP calls and returns in-memory
# mock data. Useful for UI development without a running backend.
# Set to "false" to hit the real backend.
NEXT_PUBLIC_USE_MOCKS=false

# Tenant identifier for multi-tenant deployments.
# Leave blank for single-tenant / local dev.
NEXT_PUBLIC_TENANT_ID=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Human-readable application name shown in the UI and page titles.
NEXT_PUBLIC_APP_NAME=ATS Platform

# Public URL where this frontend is served. Used for absolute links,
# redirects, and OAuth callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Backend reference (informational — not read by the frontend directly)
# -----------------------------------------------------------------------------
# The following variables are consumed by the NestJS backend (backend/.env).
# They are listed here so frontend developers know what the backend expects
# and can stand up the full stack locally.

# PostgreSQL connection string.
# DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ats_db?schema=public

# Secret used to sign JWT access tokens issued by the backend.
# Must match the value in backend/.env — never share or commit real secrets.
# JWT_SECRET=change-me-in-production

# Backend HTTP port. Must match the port in NEXT_PUBLIC_API_URL above.
# PORT=4000

# Allowed CORS origin for the backend. Should match NEXT_PUBLIC_APP_URL.
# CORS_ORIGIN=http://localhost:3000
