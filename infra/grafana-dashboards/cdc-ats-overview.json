{
  "uid": "cdc-ats-overview",
  "title": "CDC ATS — Service Overview",
  "tags": ["cdc-ats"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(http_requests_total, service)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (per service)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[1m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx error rate",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 5 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\",status=~\"5..\"}[1m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 latency (last 5m)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[1m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[1m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[1m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[1m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Status code breakdown",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total{service=~\"$service\"}[1m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node.js memory + event loop",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service) (process_resident_memory_bytes{service=~\"$service\"}) / 1024 / 1024", "legendFormat": "{{service}} RSS (MB)" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Live logs (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 10 },
      "targets": [
        { "expr": "{service=~\"$service\"}", "refId": "A" }
      ],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "dedupStrategy": "exact" }
    }
  ]
}
