# ═══════════════════════════════════════════════════════════
# ATS Backend Environment Variables
# NEVER commit the actual .env file — only .env.example
# ═══════════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ats_db

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_minimum_32_characters_required
JWT_ISSUER=ats-api
JWT_AUDIENCE=ats-client

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Google OAuth / SSO (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis (BullMQ background jobs)
REDIS_URL=redis://localhost:6379

# Sentry (error tracking)
SENTRY_DSN=

# Langfuse (LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001

# ═══════════════════════════════════════════════════════════
# AI AGENTS (REQUIRED for AI features — system works without them in manual mode)
# ═══════════════════════════════════════════════════════════
# Without these keys: all 12 AI agents return 503 "AI not configured"
# With these keys: resume parsing, screening, JD authoring, scheduling, etc. all work
#
# Get Anthropic key: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=
#
# Get OpenAI key: https://platform.openai.com → API Keys → Create new secret key
# (Used for embeddings/vector search only — agents use Anthropic)
OPENAI_API_KEY=

# Logging
LOG_LEVEL=info

# DocuSign E-Signature (optional — stub mode without these)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_EMAIL=

# Checkr Background Check (optional — stub mode without this)
CHECKR_API_KEY=
CHECKR_BASE_URL=https://api.checkr.com/v1

# Deepgram Transcription (optional — stub mode without this)
DEEPGRAM_API_KEY=
